OPENAI_API_KEY=
# 兜底模型。客户端可在「我的 → AI 服务配置」填写模型名，按请求覆盖此值。
OPENAI_MODEL=gpt-5.5
PORT=8787

# 可选：设置后，客户端必须在 x-api-key 请求头携带相同的值，否则返回 401。
# 留空则不启用鉴权（仅建议本地开发时留空）。
API_KEY=

# 每个 IP 每分钟允许的最大请求数，默认 20。
RATE_LIMIT_MAX=20

# Cloudflare R2：图片 presigned 直传 + 公开域名直读所需凭据。
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# 开发环境建议 daily-habit-dev；正式环境建议 daily-habit-prod。
R2_BUCKET=

# Android APK 自动更新：R2 上 latest.json 的公开 HTTPS 地址。
# 例如：https://lcvv.eu.org/releases/android/latest.json
APP_UPDATE_MANIFEST_URL=
