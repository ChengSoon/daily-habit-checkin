# Server no longer keeps a separate env file here.
# Use the repository root .env for shared App + Server configuration.
# Put private machine-only overrides in ../.env.local.

# 国内构建加速（可选，deploy 脚本会自动写入）
# NODE_IMAGE=docker.m.daocloud.io/library/node:22-alpine
# NPM_REGISTRY=https://registry.npmmirror.com

# 本机 npm run dev 时必填（Docker Postgres 映射到宿主机 5432）
# DATABASE_URL=postgresql://habit:habit@127.0.0.1:5432/habit
