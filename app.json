{
  "expo": {
    "name": "每日打卡",
    "slug": "daily-habit-checkin",
    "version": "1.0.17",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dailyhabitcheckin",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.dailyhabitcheckin.app",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.dailyhabitcheckin.app",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#FBE1EF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-audio-api",
        {
          "iosBackgroundMode": false,
          "androidPermissions": [],
          "androidForegroundService": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "允许每日打卡使用麦克风，和卡卡进行语音对话。",
          "speechRecognitionPermission": "允许每日打卡识别你的语音，转换为与卡卡的对话内容。",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox",
            "com.google.android.as"
          ]
        }
      ],
      "./plugins/with-utf8-pod-exec",
      "expo-sqlite",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "允许访问相册，用于为奖励商品选择图片。",
          "cameraPermission": "允许使用相机，用于为奖励商品拍摄图片。"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6cebff69-997b-47dc-951a-c7bbe8b62aa4"
      }
    }
  }
}
